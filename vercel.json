{
  "routes": [
    {
      "src": "^/sitemap.xml$",
      "headers": { "Content-Type": "application/xml" },
      "dest": "/sitemap.xml"
    },
    {
      "src": "^/sitemap-v2.xml$",
      "headers": { "Content-Type": "application/xml" },
      "dest": "/sitemap-v2.xml"
    },
    {
      "src": "^/robots.txt$",
      "dest": "/robots.txt"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.html"
    }
  ]
}